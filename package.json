{
  "name": "codeprism",
  "version": "1.0.0",
  "private": true,
  "description": "Interactive visual tutorials for Design Patterns, Data Structures & Algorithms",
  "author": "hupeng <278055491@qq.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "homepage": "https://github.com/hupeng84/codeprism",
  "repository": {
    "type": "git",
    "url": "https://github.com/hupeng84/codeprism.git"
  },
  "bugs": {
    "url": "https://github.com/hupeng84/codeprism/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:check": "node scripts/check-bundle-budget.mjs",
    "verify": "pnpm build && pnpm build:check && pnpm test && pnpm test:e2e",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "copy-monaco": "node scripts/copy-monaco.mjs",
    "postinstall": "node scripts/copy-monaco.mjs",
    "clean": "turbo clean"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@codeprism/content": "workspace:*",
    "@codeprism/core": "workspace:*",
    "@codeprism/ui": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "monaco-editor": "0.52.2",
    "next": "^15.3.0",
    "next-intl": "^4.13.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.0.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0"
  }
}
